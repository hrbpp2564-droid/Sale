{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/charts/**",
              "components/core/**",
              "components/data/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans Thai|IBM Plex Mono|IBM Plex Sans Thai Looped))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans Thai, IBM Plex Mono, IBM Plex Sans Thai Looped."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|dot|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, size, dot, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|positive|negative|warning|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'positive' | 'negative' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|disabled|fullWidth|style|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, disabled, fullWidth, style, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|actions|padding|interactive|style|bodyStyle|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, actions, padding, interactive, style, bodyStyle, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|numeric|muted|width|sortable|render|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, header, align, numeric, muted, width, sortable, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeltaBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|format|size|showArrow|invert|suffix|style|key|ref|className|style|children)$/]",
        "message": "<DeltaBadge> doesn't accept that prop. Declared props: value, format, size, showArrow, invert, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeltaBadge'] > JSXAttribute[name.name='format'] > Literal[value!=/^(?:percent|number)$/]",
        "message": "<DeltaBadge> format must be one of 'percent' | 'number'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeltaBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<DeltaBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DonutSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|color|key|ref|className|style|children)$/]",
        "message": "<DonutSegment> doesn't accept that prop. Declared props: label, value, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|active|disabled|label|style|children|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, active, disabled, label, style, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid|outline)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|detail|metric|time|onClick|style|key|ref|className|style|children)$/]",
        "message": "<InsightCard> doesn't accept that prop. Declared props: tone, icon, title, detail, metric, time, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:positive|negative|warning|info)$/]",
        "message": "<InsightCard> tone must be one of 'positive' | 'negative' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiSecondary'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<KpiSecondary> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChartSeries'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|data|color|type|axis|key|ref|className|style|children)$/]",
        "message": "<ChartSeries> doesn't accept that prop. Declared props: name, data, color, type, axis."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChartSeries'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:line|area|bar)$/]",
        "message": "<ChartSeries> type must be one of 'line' | 'area' | 'bar'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChartSeries'] > JSXAttribute[name.name='axis'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<ChartSeries> axis must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ParetoDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<ParetoDatum> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='RankBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|label|sublabel|value|ratio|share|delta|color|onClick|style|key|ref|className|style|children)$/]",
        "message": "<RankBar> doesn't accept that prop. Declared props: rank, label, sublabel, value, ratio, share, delta, color, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|color|fill|endDot|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, color, fill, endDot, strokeWidth, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
